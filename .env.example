# ─── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" on the server. Affects Prisma query logging (dev only).
NODE_ENV="production"

# Port the Next.js standalone server listens on inside the container.
# Override only if your host maps a different port; docker-compose defaults to 3000.
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string. For local dev use a local Postgres or Docker.
# For production, use a managed Postgres (Neon / Vercel Postgres / Supabase / Railway).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wedoearth?schema=public"

# ─── Email notifications (Resend) ─────────────────────────────────────────────
# Create an API key at https://resend.com/api-keys
# If left empty, lead saving still works — only the broker notification is skipped.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Verified sender domain in Resend (must match a domain you have verified in Resend).
LEADS_EMAIL_FROM="WeDoEarth Leads <leads@wedoearth.com>"

# Where new-lead notifications are delivered.
# Comma-separated for multiple recipients: "a@example.com,b@example.com"
LEADS_EMAIL_TO="sales@natarajanestates.com,karthick@webronic.com"
